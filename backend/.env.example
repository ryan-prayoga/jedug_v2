APP_NAME=jedug-api
APP_ENV=development
APP_PORT=8080
DATABASE_URL=postgresql://jedug_user:YOUR_PASSWORD@localhost:5432/jedug_db?sslmode=disable
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
ADMIN_USERNAME=admin_jedug
ADMIN_PASSWORD=JedagJedugJedagJedug

# Storage — local filesystem for development; set to r2 when Cloudflare R2 is ready
STORAGE_DRIVER=local
STORAGE_PUBLIC_BASE_URL=http://localhost:8080
UPLOAD_DIR=./uploads/gallery

# Duplicate detection (meter)
DUPLICATE_RADIUS_M=30

# Reverse geocoding fallback for human-readable road labels
REVERSE_GEOCODE_ENABLED=true
REVERSE_GEOCODE_URL=https://nominatim.openstreetmap.org/reverse
REVERSE_GEOCODE_USER_AGENT=jedug-api/1.0
REVERSE_GEOCODE_TIMEOUT_MS=2000
REVERSE_GEOCODE_CACHE_TTL_SEC=300
UPLOAD_TOKEN_SECRET=
UPLOAD_TICKET_TTL_SEC=600
UPLOAD_PENDING_WINDOW_SEC=1800
UPLOAD_PENDING_LIMIT=4
FOLLOWER_TOKEN_SECRET=awgwEPKi6WnPcQCgRAYhGCAHmAdmEG1Z
FOLLOWER_TOKEN_TTL_SEC=604800

# Cloudflare R2 (required when STORAGE_DRIVER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=

# Browser Web Push (set all four together to enable)
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBSCRIBER=mailto:ops@example.com
WEB_PUSH_SITE_URL=http://localhost:5173
WEB_PUSH_TTL_SEC=300

# Ops / retention
MAINTENANCE_ENABLED=true
MAINTENANCE_INTERVAL_SEC=21600
NOTIFICATIONS_RETENTION_DAYS=90
PUSH_SUBSCRIPTIONS_STALE_DAYS=180
PUSH_SUBSCRIPTIONS_DISABLED_RETENTION_DAYS=30
PUSH_DELIVERY_DELIVERED_RETENTION_DAYS=14
PUSH_DELIVERY_FAILED_RETENTION_DAYS=30
UPLOAD_ORPHAN_RETENTION_SEC=43200
